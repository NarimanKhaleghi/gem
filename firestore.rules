rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidUserSecret(data) {
        return data.keys().hasAll(['encryptedData', 'updatedAt']) && data.keys().size() == 2
            && data.encryptedData is string && data.encryptedData.size() <= 1048576
            && data.updatedAt is number;
    }

    function isValidChatSync(data) {
        return data.keys().hasAll(['encryptedData', 'updatedAt']) && data.keys().size() == 2
            && data.encryptedData is string && data.encryptedData.size() <= 1048576
            && data.updatedAt is number;
    }

    match /users/{userId}/secrets/main {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && isValidUserSecret(request.resource.data);
      allow update: if isOwner(userId) && isValidUserSecret(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/chats/{chatId} {
      allow get: if isOwner(userId) && isValidId(chatId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(chatId) && isValidChatSync(request.resource.data);
      allow update: if isOwner(userId) && isValidId(chatId) && isValidChatSync(request.resource.data);
      allow delete: if isOwner(userId) && isValidId(chatId);
    }
  }
}
